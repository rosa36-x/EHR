meta {
  name: Get Audit History - Patient Own Records (Tests BUG-02 Fix)
  type: http
  seq: 3
}

get {
  url: {{base_url}}/audit-history/{{audit_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{patient_token}}
}

// This tests BUG-02 fix: patient should be able to view audit logs where
// resourceID matches their patientID (records about their data being accessed),
// not just logs where they were the actor.
// The audit log created in 01_create has resourceID = consultation_id,
// which itself references patient_id. However, the audit log's resourceID
// field stores the consultation/record ID, not patientID directly.
//
// For a cleaner BUG-02 test: the auto-generated audit logs from record
// creation (e.g. from 06_Consultation/01) have resourceID = patient_id.
// Those are the logs where this fix matters. Use one of those auditIDs here.

tests {
  test("status 200 or 403", function() {
    // 200 = patient can see this audit log (resourceID matches their data)
    // 403 = patient cannot see this specific audit log (expected for some)
    expect([200, 403]).to.include(res.status);
  });
  test("if 200 — data is present", function() {
    if (res.status === 200) {
      expect(res.body.status).to.equal("SUCCESS");
      expect(res.body.data).to.be.an("object");
    }
  });
  test("if 403 — FAILED status with meaningful message", function() {
    if (res.status === 403) {
      expect(res.body.status).to.equal("FAILED");
      expect(res.body.message).to.include("access denied").or.include("Access denied");
    }
  });
}
