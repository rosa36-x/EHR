meta {
  name: Get Consultation (Metadata)
  type: http
  seq: 3
}

get {
  url: {{base_url}}/consultations/{{consultation_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{doctor_token}}
}

// Prerequisites: active treatment relationship must exist between
// doctor_id and patient_id (run 05_TreatmentRelationship/01 first,
// and 05/05_reactivate if you ran the dormant test).

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("SUCCESS status", function() {
    expect(res.body.status).to.equal("SUCCESS");
  });
  test("consultation data contains expected fields", function() {
    var d = res.body.data;
    expect(d.patientID).to.equal(bru.getEnvVar("patient_id"));
    expect(d.sensitivityLevel).to.equal("NORMAL");
    expect(d.consultationCID).to.be.a("string");
  });
}
