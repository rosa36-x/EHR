meta {
  name: Security - Malformed JWT (Tampered Signature)
  type: http
  seq: 10
}

get {
  url: {{base_url}}/consultations/{{consultation_id}}
  body: none
  auth: bearer
}

auth:bearer {
  // Valid structure, but signature bytes changed — should fail verification.
  token: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IkRPQzAwMDEiLCJyb2xlIjoiZG9jdG9yIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjk5OTk5OTk5OTl9.INVALIDSIGNATUREXXXXXXXXXXXXXXXXXXXXXXXXXXXX
}

tests {
  test("status 401", function() {
    expect(res.status).to.equal(401);
  });
  test("FAILED status", function() {
    expect(res.body.status).to.equal("FAILED");
  });
  test("error mentions invalid token", function() {
    expect(res.body.message).to.satisfy(function(m) {
      return m.includes("Invalid") || m.includes("invalid") || m.includes("signature");
    });
  });
}
