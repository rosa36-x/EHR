meta {
  name: Security - Access Record Without Treatment Relationship
  type: http
  seq: 8
}

// To run this test:
// 1. Register a SECOND doctor (different phone/email/license).
// 2. Log in as that second doctor, get their token.
// 3. Paste the second doctor's token here.
// 4. That doctor has no treatment relationship with patient_id,
//    so accessing the normal consultation should be denied.

get {
  url: {{base_url}}/consultations/{{consultation_id}}
  body: none
  auth: bearer
}

auth:bearer {
  // Replace with a token for a doctor who has NO treatment relationship with patient_id
  token: SECOND_DOCTOR_TOKEN_WITH_NO_TREATMENT_RELATIONSHIP
}

tests {
  test("ACCESS_DENIED without treatment relationship", function() {
    // Service returns ACCESS_DENIED which the route maps to 500
    expect(res.status).to.equal(500);
    expect(res.body.status).to.equal("ACCESS_DENIED");
  });
  test("error mentions treatment relationship", function() {
    expect(res.body.message).to.include("treatment relationship");
  });
}
