meta {
  name: Doctor Login - Wrong Password
  type: http
  seq: 4
}

post {
  url: {{base_url}}/auth/doctor/login
  body: json
  auth: none
}

body:json {
  {
    "phone": "{{doctor_phone}}",
    "password": "WrongPassword999"
  }
}

tests {
  test("status 401", function() {
    expect(res.status).to.equal(401);
  });
  test("FAILED status", function() {
    expect(res.body.status).to.equal("FAILED");
  });
  test("no token in response", function() {
    expect(res.body.token).to.be.undefined;
  });
}
