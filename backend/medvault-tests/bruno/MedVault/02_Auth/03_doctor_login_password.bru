meta {
  name: Doctor Login (Password)
  type: http
  seq: 3
}

post {
  url: {{base_url}}/auth/doctor/login
  body: json
  auth: none
}

body:json {
  {
    "phone": "{{doctor_phone}}",
    "password": "{{doctor_password}}"
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("SUCCESS status", function() {
    expect(res.body.status).to.equal("SUCCESS");
  });
  test("JWT token returned", function() {
    expect(res.body.token).to.be.a("string");
    // JWT has 3 dot-separated parts
    expect(res.body.token.split(".").length).to.equal(3);
    bru.setEnvVar("doctor_token", res.body.token);
  });
  test("doctorID matches registered ID", function() {
    expect(res.body.doctorID).to.equal(bru.getEnvVar("doctor_id"));
  });
}
