meta {
  name: Get Permission Request
  type: http
  seq: 2
}

get {
  url: {{base_url}}/permission-requests/{{permission_request_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{doctor_token}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("status is PENDING", function() {
    expect(res.body.data.status).to.equal("PENDING");
  });
  test("doctorID and patientID match", function() {
    expect(res.body.data.doctorID).to.equal(bru.getEnvVar("doctor_id"));
    expect(res.body.data.patientID).to.equal(bru.getEnvVar("patient_id"));
  });
}
