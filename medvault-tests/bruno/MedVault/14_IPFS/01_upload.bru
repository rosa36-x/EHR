meta {
  name: IPFS Upload File
  type: http
  seq: 1
}

post {
  url: {{base_url}}/ipfs/upload
  body: multipart-form
  auth: none
}

body:multipart-form {
  file: @file(/path/to/test_ipfs_payload.pdf)
}

tests {
  // Update file path before running.
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("success true", function() {
    expect(res.body.success).to.equal(true);
  });
  test("CID returned", function() {
    expect(res.body.cid).to.be.a("string");
    expect(res.body.cid.length).to.be.at.least(10);
    bru.setEnvVar("ipfs_test_cid", res.body.cid);
  });
}
