meta {
  name: Authenticate (Aadhaar + DOB)
  type: http
  seq: 2
}

post {
  url: {{base_url}}/uidai/authenticate
  body: json
  auth: none
}

body:json {
  {
    "aadhaarNumber": "{{aadhaar_number}}",
    "dob": "{{aadhaar_dob}}"
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("OTP_SENT status", function() {
    expect(res.body.status).to.equal("OTP_SENT");
  });
  test("transactionID returned", function() {
    expect(res.body.transactionID).to.be.a("string");
    expect(res.body.transactionID).to.match(/^TXN/);
  });

  // Save for OTP verify step
  bru.setEnvVar("uidai_transaction_id", res.body.transactionID);
}
