meta {
  name: Security - Wrong Role (Patient Token on Doctor Route)
  type: http
  seq: 3
}

post {
  url: {{base_url}}/treatment-relationships
  body: json
  auth: bearer
}

auth:bearer {
  token: {{patient_token}}
}

body:json {
  {
    "patientID": "{{patient_id}}",
    "relationshipType": "RECENT_APPOINTMENT"
  }
}

tests {
  // treatment-relationships POST is restricted to role "doctor" via authorizeRoles().
  // Sending a patient token should yield 403.
  test("status 403", function() {
    expect(res.status).to.equal(403);
  });
  test("FAILED status", function() {
    expect(res.body.status).to.equal("FAILED");
  });
  test("error mentions required role", function() {
    expect(res.body.message).to.include("doctor");
  });
}
