meta {
  name: Doctor Login - OTP Initiate
  type: http
  seq: 5
}

post {
  url: {{base_url}}/auth/doctor/otp/initiate
  body: json
  auth: none
}

body:json {
  {
    "phone": "{{doctor_phone}}"
  }
}

tests {
  // NOTE: In dev mode, the OTP is printed to the server console.
  // Copy the OTP from the console log and paste it into the
  // 06_doctor_otp_verify request before running it.
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("OTP_SENT status", function() {
    expect(res.body.status).to.equal("OTP_SENT");
  });
}
