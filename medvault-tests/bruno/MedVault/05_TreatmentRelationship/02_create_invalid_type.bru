meta {
  name: Create Treatment Relationship - Invalid Type
  type: http
  seq: 2
}

post {
  url: {{base_url}}/treatment-relationships
  body: json
  auth: bearer
}

auth:bearer {
  token: {{doctor_token}}
}

body:json {
  {
    "patientID": "{{patient_id}}",
    "relationshipType": "INVALID_TYPE"
  }
}

tests {
  test("status 500", function() {
    expect(res.status).to.equal(500);
  });
  test("FAILED status", function() {
    expect(res.body.status).to.equal("FAILED");
  });
  test("error mentions valid types", function() {
    expect(res.body.message).to.include("RECENT_APPOINTMENT");
  });
}
