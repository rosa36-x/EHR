{
  "name": "medvault-tests",
  "version": "1.0.0",
  "description": "MedVault backend test suite — unit + integration",
  "private": true,
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=src/unit --runInBand --forceExit",
    "test:integration": "jest --testPathPattern=src/integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "globalSetup": "<rootDir>/jest.globalSetup.js",
    "moduleNameMapper": {
      "^../services/notificationService$": "<rootDir>/src/__mocks__/notificationService.js",
      "^../../services/notificationService$": "<rootDir>/src/__mocks__/notificationService.js"
    },
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "../../routes/**/*.js",
      "../../services/**/*.js",
      "!../../services/fabricService.js"
    ]
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "babel-jest": "^30.4.1",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "supertest": "^6.3.4"
  }
}